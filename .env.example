# ================================================================
# GENSYS — Environment Variables
# Salin file ini ke .env dan sesuaikan nilainya.
# ================================================================

# ── SERVER ───────────────────────────────────────────────────────
SERVER_PORT=3023
HOST=0.0.0.0
BACKEND_URL=http://localhost:3023
DEFAULT_REPORT_DEVICE_ID=ESP32_GENERATOR_01

# ── DATABASE ─────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/gensys

# ── MQTT ─────────────────────────────────────────────────────────
MQTT_BROKER=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ── EMAIL ALERT (SendGrid) ───────────────────────────────────────
SENDGRID_API_KEY=
ALERT_EMAIL_TO=

# ================================================================
# FEATURE FLAGS
# Nilai: true (aktif) | false (nonaktif)
# Default semua true jika tidak diset.
# ================================================================

# ── Analysis Engine ──────────────────────────────────────────────

# CBM: Condition-Based Maintenance analysis
# Metode: Linear Regression, Threshold Proximity, CV
# Ref: ISO 13374, IEC 61511, IEC 61000-4-30
ENABLE_CBM=true

# FFT peak mapping ke komponen mekanik (unbalance, bearing, misfire)
# Metode: Spectral analysis, rasio harmonik 0.5x/1x/2x RPM
# Ref: ISO 10816, ISO 20816
ENABLE_FFT_MAPPING=true

# Component lifespan estimation (estimasi sisa umur tiap komponen)
# Metode: Arrhenius degradation model + Miner's Rule
# Ref: Miner 1945, MIL-HDBK-217F
ENABLE_COMPONENT_LIFE=true

# Health score computation (skor 0-100 dari penalty findings)
# Metode: Weighted penalty scoring (mirip RPN dari FMEA)
# Ref: IEC 60812, ISO 14224
ENABLE_HEALTH_SCORE=true

# Preventive schedule berbasis interval jam operasi
# Metode: Time-Based Maintenance (TBM)
# Ref: ISO 55000, NFPA 110
ENABLE_PREVENTIVE_SCHEDULE=true

# ── Background Workers ───────────────────────────────────────────

# Worker CBM: simpan hasil CBM ke MongoDB tiap interval
ENABLE_CBM_WORKER=true
CBM_WORKER_INTERVAL_MS=3600000         # default: 1 jam

# Worker component life: cek early warning & buat MaintenanceSuggestion
ENABLE_COMPONENT_LIFE_WORKER=true
COMPONENT_LIFE_WORKER_INTERVAL_MS=3600000  # default: 1 jam

# Worker maintenance suggestion: generate saran dari sensor terbaru
ENABLE_MAINTENANCE_WORKER=true
MAINTENANCE_WORKER_INTERVAL_MS=3600000     # default: 1 jam
MAINTENANCE_SUGGESTION_STALE_MS=86400000   # jangan buat saran baru jika < 24 jam

# Worker laporan bulanan
ENABLE_REPORT_WORKER=true
REPORT_WORKER_INTERVAL_MS=21600000         # default: 6 jam

# ── Notifications ────────────────────────────────────────────────

# Kirim email alert saat ada parameter critical
ENABLE_ALERT_EMAIL=true

# ================================================================
# CONTOH PENGGUNAAN DARI TERMINAL
# ================================================================
#
# Disable CBM saja:
#   ENABLE_CBM=false node server.js
#
# Disable semua worker (hanya API, tanpa background job):
#   ENABLE_CBM_WORKER=false ENABLE_COMPONENT_LIFE_WORKER=false \
#   ENABLE_MAINTENANCE_WORKER=false ENABLE_REPORT_WORKER=false \
#   node server.js
#
# Mode minimal (hanya server + MQTT, tanpa semua analisis):
#   ENABLE_CBM=false ENABLE_COMPONENT_LIFE=false \
#   ENABLE_FFT_MAPPING=false ENABLE_HEALTH_SCORE=false \
#   ENABLE_PREVENTIVE_SCHEDULE=false ENABLE_ALERT_EMAIL=false \
#   ENABLE_CBM_WORKER=false ENABLE_COMPONENT_LIFE_WORKER=false \
#   ENABLE_MAINTENANCE_WORKER=false ENABLE_REPORT_WORKER=false \
#   node server.js
#
# Toggle runtime tanpa restart (curl):
#   curl -X POST http://localhost:3023/api/features/cbm \
#        -H "Content-Type: application/json" \
#        -d '{"enabled": false}'
#
# Lihat semua flag:
#   curl http://localhost:3023/api/features
# ================================================================
