# Server HTTP port. Do not set this to the MQTT broker port (1883/8883).
SERVER_PORT=3023
# PORT is also supported for hosting platforms that inject it automatically.
# PORT=3023
BACKEND_URL=https://your-backend.example.com

# MongoDB
MONGODB_URI=mongodb://username:password@host:27017/database?authSource=database
MONGODB_SERVER_SELECTION_TIMEOUT_MS=30000
MONGODB_SOCKET_TIMEOUT_MS=45000
MONGODB_CONNECT_TIMEOUT_MS=30000

# RabbitMQ MQTT broker
MQTT_BROKER=mqtt://your-mqtt-broker.example.com:1883
MQTT_VHOST=/your-vhost
MQTT_USERNAME=your-mqtt-username
MQTT_PASSWORD=your-mqtt-password
# Optional override when broker expects a custom auth username format.
# MQTT_AUTH_USERNAME=/your-vhost:your-mqtt-username

# Serverless runtime toggles
ENABLE_SERVERLESS_MQTT=false
ENABLE_SERVERLESS_DB_WARMUP=false

# Email
SENDGRID_API_KEY=
SENDER_EMAIL=
ALERT_EMAIL_FROM=onboarding@resend.dev
ALERT_EMAIL_COOLDOWN_MS=60000
RESEND_API_KEY=
